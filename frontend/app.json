{
  "expo": {
    "name": "MediAssist",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mediassist",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan medications to identify them",
        "NSPhotoLibraryUsageDescription": "Pick medication photos to identify",
        "NSLocationWhenInUseUsageDescription": "Find pharmacies near you"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FCFBF8"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FCFBF8"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MediAssist to access camera to scan medications"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow MediAssist to pick medication photos"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow MediAssist to find nearby pharmacies"
        }
      ],
      "expo-notifications",
      "expo-background-task"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
